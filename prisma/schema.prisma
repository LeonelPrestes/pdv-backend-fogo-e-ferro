generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLOSING
}

enum TabStatus {
  OPEN
  CLOSED
  CANCELED
  TRANSFERRED
}

enum OrderStatus {
  PENDING
  SENT_TO_KITCHEN
  PREPARING
  READY
  DELIVERED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  CANCELED
  ON_CREDIT
}

enum DeliveryStatus {
  WAITING
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELED
}

enum StockMovementType {
  ENTRADA
  SAIDA_VENDA
  AJUSTE_MANUAL
  CANCELAMENTO
  PERDA
  DEVOLUCAO
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING
  SALE
  CASH_IN
  CASH_OUT
  CLOSING
}

enum PaymentMethod {
  MONEY
  PIX
  CREDIT_CARD
  DEBIT_CARD
  ON_CREDIT
  OTHER
}

enum ModuleKey {
  TABLES
  TABS
  ORDERS
  KITCHEN
  PRODUCTS
  STOCK
  CASH_REGISTER
  PAYMENTS
  CUSTOMERS
  DELIVERY
  WHATSAPP
  REPORTS
  SETTINGS
}

enum ModuleStatus {
  ACTIVE
  INACTIVE
}

model Restaurant {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  document        String?
  active          Boolean             @default(true)
  users           User[]
  modules         RestaurantModule[]
  tables          RestaurantTable[]
  tabs            Tab[]
  orders          Order[]
  categories      Category[]
  products        Product[]
  stockMovements  StockMovement[]
  customers       Customer[]
  deliveries      Delivery[]
  payments        Payment[]
  cashRegisters   CashRegister[]
  kitchenTickets  KitchenTicket[]
  settings        Setting[]
  productionAreas ProductionArea[]
  auditLogs       AuditLog[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("restaurants")
}

model Module {
  key         ModuleKey          @id
  name        String
  description String?
  status      ModuleStatus       @default(ACTIVE)
  restaurants RestaurantModule[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("modules")
}

model RestaurantModule {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  moduleKey    ModuleKey
  module       Module     @relation(fields: [moduleKey], references: [key])
  enabled      Boolean    @default(false)
  enabledAt    DateTime?
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, moduleKey])
  @@map("restaurant_modules")
}

model User {
  id             String         @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id])
  name           String
  email          String
  passwordHash   String
  role           UserRole       @default(WAITER)
  active         Boolean        @default(true)
  openedCash     CashRegister[] @relation("CashOpenedBy")
  closedCash     CashRegister[] @relation("CashClosedBy")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([restaurantId, email])
  @@map("users")
}

model RestaurantTable {
  id        String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  number    Int
  name      String?
  status    TableStatus @default(AVAILABLE)
  tabs      Tab[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([restaurantId, number])
  @@map("tables")
}

model Tab {
  id                       String     @id @default(cuid())
  restaurantId             String
  restaurant               Restaurant @relation(fields: [restaurantId], references: [id])
  code                     String
  customerName             String?
  status                   TabStatus  @default(OPEN)
  serviceFeeEnabled        Boolean    @default(true)
  serviceFeePercent        Decimal    @default(10) @db.Decimal(5, 2)
  tableId                  String?
  table                    RestaurantTable? @relation(fields: [tableId], references: [id])
  transferredFromTabId     String?
  orders                   Order[]
  payments                 Payment[]
  openedAt                 DateTime   @default(now())
  closedAt                 DateTime?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@unique([restaurantId, code])
  @@map("tabs")
}

model Order {
  id                 String        @id @default(cuid())
  restaurantId       String
  restaurant         Restaurant    @relation(fields: [restaurantId], references: [id])
  sequentialNumber   Int
  status             OrderStatus   @default(PENDING)
  notes              String?
  isDelivery         Boolean       @default(false)
  tabId              String?
  tab                Tab?          @relation(fields: [tabId], references: [id])
  items              OrderItem[]
  delivery           Delivery?
  kitchenTicket      KitchenTicket?
  sentToKitchenAt    DateTime?
  startedPreparingAt DateTime?
  readyAt            DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("orders")
}

model OrderItem {
  id                String  @id @default(cuid())
  orderId           String
  order             Order   @relation(fields: [orderId], references: [id])
  productId         String
  product           Product @relation(fields: [productId], references: [id])
  quantity          Decimal @db.Decimal(10, 3)
  unitPrice         Decimal @db.Decimal(10, 2)
  discountAmount    Decimal @default(0) @db.Decimal(10, 2)
  notes             String?
  canceledAt        DateTime?
  cancellationReason String?
  createdAt         DateTime @default(now())

  @@map("order_items")
}

model Category {
  id        String    @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name      String
  active    Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([restaurantId, name])
  @@map("categories")
}

model Product {
  id             String          @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  name           String
  description    String?
  imageUrl       String?
  price          Decimal         @db.Decimal(10, 2)
  currentStock   Decimal         @default(0) @db.Decimal(10, 3)
  allowNegativeStock Boolean      @default(true)
  available      Boolean         @default(true)
  categoryId     String?
  category       Category?       @relation(fields: [categoryId], references: [id])
  productionAreaId String?
  productionArea   ProductionArea? @relation(fields: [productionAreaId], references: [id])
  orderItems     OrderItem[]
  stockMovements StockMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([restaurantId, name])
  @@map("products")
}

model StockMovement {
  id             String            @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id])
  productId      String
  product        Product           @relation(fields: [productId], references: [id])
  type           StockMovementType
  quantity       Decimal           @db.Decimal(10, 3)
  reason         String?
  orderItemId    String?
  createdAt      DateTime          @default(now())

  @@map("stock_movements")
}

model Customer {
  id        String            @id @default(cuid())
  restaurantId String
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id])
  name      String
  phone     String?
  addresses CustomerAddress[]
  deliveries Delivery[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("customers")
}

model CustomerAddress {
  id          String     @id @default(cuid())
  customerId  String
  customer    Customer   @relation(fields: [customerId], references: [id])
  street      String
  number      String
  complement  String?
  district    String
  city        String
  state       String
  zipCode     String?
  deliveries  Delivery[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("customer_addresses")
}

model Delivery {
  id          String         @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  orderId     String         @unique
  order       Order          @relation(fields: [orderId], references: [id])
  customerId  String
  customer    Customer       @relation(fields: [customerId], references: [id])
  addressId   String
  address     CustomerAddress @relation(fields: [addressId], references: [id])
  status      DeliveryStatus @default(WAITING)
  feeAmount   Decimal        @default(0) @db.Decimal(10, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("deliveries")
}

model Payment {
  id             String        @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant    @relation(fields: [restaurantId], references: [id])
  tabId          String?
  tab            Tab?          @relation(fields: [tabId], references: [id])
  cashRegisterId String?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])
  method         PaymentMethod
  status         PaymentStatus @default(PAID)
  amount         Decimal       @db.Decimal(10, 2)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  @@map("payments")
}

model CashRegister {
  id               String             @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id])
  openedAt         DateTime           @default(now())
  closedAt         DateTime?
  openingAmount    Decimal            @db.Decimal(10, 2)
  closingAmount    Decimal?           @db.Decimal(10, 2)
  expectedAmount   Decimal?           @db.Decimal(10, 2)
  differenceAmount Decimal?           @db.Decimal(10, 2)
  status           CashRegisterStatus @default(OPEN)
  openedById       String
  openedBy         User               @relation("CashOpenedBy", fields: [openedById], references: [id])
  closedById       String?
  closedBy         User?              @relation("CashClosedBy", fields: [closedById], references: [id])
  payments         Payment[]
  movements        CashMovement[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("cash_registers")
}

model CashMovement {
  id             String           @id @default(cuid())
  cashRegisterId String
  cashRegister   CashRegister     @relation(fields: [cashRegisterId], references: [id])
  type           CashMovementType
  amount         Decimal          @db.Decimal(10, 2)
  reason         String?
  createdAt      DateTime         @default(now())

  @@map("cash_movements")
}

model KitchenTicket {
  id                 String      @id @default(cuid())
  restaurantId       String
  restaurant         Restaurant  @relation(fields: [restaurantId], references: [id])
  orderId             String      @unique
  order               Order       @relation(fields: [orderId], references: [id])
  priority            Int         @default(0)
  productionAreaId    String?
  productionArea      ProductionArea? @relation(fields: [productionAreaId], references: [id])
  status              OrderStatus @default(SENT_TO_KITCHEN)
  notes               String?
  sentToKitchenAt     DateTime    @default(now())
  startedPreparingAt  DateTime?
  readyAt             DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@map("kitchen_tickets")
}

model Setting {
  id        String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, key])
  @@map("settings")
}

model ProductionArea {
  id           String          @id @default(cuid())
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id])
  name         String
  key          String
  active       Boolean         @default(true)
  products     Product[]
  tickets      KitchenTicket[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([restaurantId, key])
  @@map("production_areas")
}

model AuditLog {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  userId       String?
  action       String
  entity       String
  entityId     String?
  metadata     Json?
  createdAt    DateTime   @default(now())

  @@map("audit_logs")
}
